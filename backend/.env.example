# Enmask Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Enmask SDM Platform
BACKEND_CORS_ORIGINS=https://tu-frontend.railway.app,https://tu-backend.railway.app

# Optional API security key (X-API-KEY header)
API_KEY=supersecret

# JWT + Google auth settings
SECRET_KEY=tu_clave_secreta_muy_segura_aqui
GOOGLE_CLIENT_ID=tu_google_client_id_de_consola_developers
ADMIN_EMAILS=tu_email_admin@example.com

# Metadata storage backends (elige uno)
REPOSITORY_BACKEND=memory  # o postgres o mongodb
POSTGRES_META_DSN=postgresql+asyncpg://usuario:password@host:5432/enmask_meta
MONGODB_META_URI=mongodb+srv://usuario:password@cluster.mongodb.net/enmask_meta
METADATA_DATABASE=enmask_meta
